NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://postgres:password@localhost:5432/syncmind
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_RUN_node_crypto_randomBytes_64_toString_hex
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

OPENAI_API_KEY=sk-proj-REPLACE_WITH_OPENAI_API_KEY

PINECONE_API_KEY=REPLACE_WITH_PINECONE_API_KEY
PINECONE_INDEX=syncmind-transcripts
PINECONE_ENVIRONMENT=us-east-1

CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_CLOUDINARY_API_SECRET

RESEND_API_KEY=re_REPLACE_WITH_RESEND_API_KEY
FROM_EMAIL=onboarding@resend.dev
